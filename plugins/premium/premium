import { 
  redeemPremiumToken, 
  isPremium, 
  getPremiumInfo,
  setBotConfig,
  getBotConfig,
  setSubbotPremium,
  removeSubbotPremium,
  isSubbotPremium,
  normalize
} from '../../lib/premium.js'

let handler = async (m, { conn, args, command, usedPrefix }) => {
  const premium = isPremium(m.sender)
  const info = getPremiumInfo(m.sender)
  
  switch (command) {
    case 'canjearp':
      if (premium) {
        return conn.sendMessage(m.chat, { text: '❌ Ya eres usuario premium' }, { quoted: m })
      }
      if (!args[0]) {
        return conn.sendMessage(m.chat, { 
          text: `❌ Debes proporcionar un token\n\nEjemplo: ${usedPrefix}canjearp ASTA-XXXXX` 
        }, { quoted: m })
      }
      const result = redeemPremiumToken(m.sender, args[0].toUpperCase())
      await conn.sendMessage(m.chat, { text: result.message }, { quoted: m })
      break
      
    case 'mipremium':
      if (!premium) {
        return conn.sendMessage(m.chat, { text: '❌ No eres usuario premium' }, { quoted: m })
      }
      let txt = '👑 *Información Premium*\n\n'
      txt += `📅 Registrado: ${new Date(info.registeredAt).toLocaleString()}\n`
      txt += `🎫 Token: \`${info.token}\`\n`
      txt += `⏰ Estado: Activo`
      await conn.sendMessage(m.chat, { text: txt }, { quoted: m })
      break
      
    case 'setnamebot':
      if (!premium) return conn.sendMessage(m.chat, { text: '❌ Comando solo para premium' }, { quoted: m })
      if (!args[0]) return conn.sendMessage(m.chat, { text: `❌ Uso: ${usedPrefix}setnamebot <nombre>` }, { quoted: m })
      const name = args.join(' ')
      setBotConfig(m.sender, { namebot: name })
      global.namebot = name
      await conn.sendMessage(m.chat, { text: `✅ Nombre del bot actualizado a: *${name}*` }, { quoted: m })
      break
      
    case 'setchannel':
      if (!premium) return conn.sendMessage(m.chat, { text: '❌ Comando solo para premium' }, { quoted: m })
      if (!args[0]) return conn.sendMessage(m.chat, { text: `❌ Uso: ${usedPrefix}setchannel <url>` }, { quoted: m })
      setBotConfig(m.sender, { channel: args[0] })
      global.channel = args[0]
      await conn.sendMessage(m.chat, { text: `✅ Canal actualizado` }, { quoted: m })
      break
      
    case 'setidchannel':
      if (!premium) return conn.sendMessage(m.chat, { text: '❌ Comando solo para premium' }, { quoted: m })
      if (!args[0]) return conn.sendMessage(m.chat, { text: `❌ Uso: ${usedPrefix}setidchannel <id>` }, { quoted: m })
      setBotConfig(m.sender, { IDchannel: args[0] })
      global.IDchannel = args[0]
      await conn.sendMessage(m.chat, { text: `✅ ID del canal actualizado` }, { quoted: m })
      break
      
    case 'setgrupo':
      if (!premium) return conn.sendMessage(m.chat, { text: '❌ Comando solo para premium' }, { quoted: m })
      if (!args[0]) return conn.sendMessage(m.chat, { text: `❌ Uso: ${usedPrefix}setgrupo <url>` }, { quoted: m })
      setBotConfig(m.sender, { grupo: args[0] })
      global.grupo = args[0]
      await conn.sendMessage(m.chat, { text: `✅ Grupo actualizado` }, { quoted: m })
      break
      
    case 'setcomunidad':
      if (!premium) return conn.sendMessage(m.chat, { text: '❌ Comando solo para premium' }, { quoted: m })
      if (!args[0]) return conn.sendMessage(m.chat, { text: `❌ Uso: ${usedPrefix}setcomunidad <url>` }, { quoted: m })
      setBotConfig(m.sender, { comunidad: args[0] })
      global.comunidad = args[0]
      await conn.sendMessage(m.chat, { text: `✅ Comunidad actualizada` }, { quoted: m })
      break
      
    case 'seticono':
      if (!premium) return conn.sendMessage(m.chat, { text: '❌ Comando solo para premium' }, { quoted: m })
      if (!args[0]) return conn.sendMessage(m.chat, { text: `❌ Uso: ${usedPrefix}seticono <url>` }, { quoted: m })
      setBotConfig(m.sender, { icono: args[0] })
      global.icono = args[0]
      await conn.sendMessage(m.chat, { text: `✅ Icono actualizado` }, { quoted: m })
      break
      
    case 'setlogo':
      if (!premium) return conn.sendMessage(m.chat, { text: '❌ Comando solo para premium' }, { quoted: m })
      if (!args[0]) return conn.sendMessage(m.chat, { text: `❌ Uso: ${usedPrefix}setlogo <url>` }, { quoted: m })
      setBotConfig(m.sender, { logo: args[0] })
      global.logo = args[0]
      await conn.sendMessage(m.chat, { text: `✅ Logo actualizado` }, { quoted: m })
      break
      
    case 'setfirma':
      if (!premium) return conn.sendMessage(m.chat, { text: '❌ Comando solo para premium' }, { quoted: m })
      if (!args[0]) return conn.sendMessage(m.chat, { text: `❌ Uso: ${usedPrefix}setfirma <texto>` }, { quoted: m })
      const firma = args.join(' ')
      setBotConfig(m.sender, { firma: firma })
      global.firma = firma
      await conn.sendMessage(m.chat, { text: `✅ Firma actualizada` }, { quoted: m })
      break
      
    case 'miconfig':
      if (!premium) return conn.sendMessage(m.chat, { text: '❌ Comando solo para premium' }, { quoted: m })
      const cfg = getBotConfig(m.sender)
      let configTxt = '⚙️ *Mi Configuración*\n\n'
      configTxt += `📝 Nombre: ${cfg.namebot}\n`
      configTxt += `📢 Canal: ${cfg.channel || 'No configurado'}\n`
      configTxt += `🆔 ID Canal: ${cfg.IDchannel || 'No configurado'}\n`
      configTxt += `👥 Grupo: ${cfg.grupo || 'No configurado'}\n`
      configTxt += `🌐 Comunidad: ${cfg.comunidad || 'No configurada'}\n`
      configTxt += `🖼️ Icono: ${cfg.icono ? 'Configurado' : 'No configurado'}\n`
      configTxt += `🎨 Logo: ${cfg.logo ? 'Configurado' : 'No configurado'}\n`
      configTxt += `✏️ Firma: ${cfg.firma || 'No configurada'}`
      await conn.sendMessage(m.chat, { text: configTxt }, { quoted: m })
      break
      
    case 'subprem':
      if (!premium) return conn.sendMessage(m.chat, { text: '❌ Comando solo para premium' }, { quoted: m })
      let target
      if (m.mentionedJid && m.mentionedJid.length > 0) {
        target = m.mentionedJid[0]
      } else if (args[0]) {
        target = args[0] + '@s.whatsapp.net'
      } else {
        return conn.sendMessage(m.chat, { 
          text: `❌ Menciona o escribe el número\n\nEjemplo: ${usedPrefix}subprem @usuario` 
        }, { quoted: m })
      }
      const resultSub = setSubbotPremium(m.sender, target)
      await conn.sendMessage(m.chat, { 
        text: resultSub.message,
        mentions: resultSub.mentions || []
      }, { quoted: m })
      break
      
    case 'delsubprem':
      if (!premium) return conn.sendMessage(m.chat, { text: '❌ Comando solo para premium' }, { quoted: m })
      let target2
      if (m.mentionedJid && m.mentionedJid.length > 0) {
        target2 = m.mentionedJid[0]
      } else if (args[0]) {
        target2 = args[0] + '@s.whatsapp.net'
      } else {
        return conn.sendMessage(m.chat, { 
          text: `❌ Menciona o escribe el número\n\nEjemplo: ${usedPrefix}delsubprem @usuario` 
        }, { quoted: m })
      }
      const resultDel = removeSubbotPremium(m.sender, target2)
      await conn.sendMessage(m.chat, { text: resultDel.message }, { quoted: m })
      break
      
    case 'listsubprem':
      if (!premium) return conn.sendMessage(m.chat, { text: '❌ Comando solo para premium' }, { quoted: m })
      const { loadSubprem } = await import('../../lib/premium.js')
      const subData = loadSubprem()
      const mySubs = Object.entries(subData.subbots)
        .filter(([_, info]) => normalize(info.registeredBy) === normalize(m.sender))
      
      if (mySubs.length === 0) {
        await conn.sendMessage(m.chat, { text: '📋 No tienes sub-bots premium registrados' }, { quoted: m })
      } else {
        let txt = '🤖 *Mis Sub-bots Premium*\n\n'
        mySubs.forEach(([num, info], i) => {
          txt += `${i + 1}. +${num} - ${new Date(info.registeredAt).toLocaleString()}\n`
        })
        await conn.sendMessage(m.chat, { text: txt }, { quoted: m })
      }
      break
  }
}

handler.help = [
  'canjearp', 'mipremium', 'setnamebot', 'setchannel', 'setidchannel',
  'setgrupo', 'setcomunidad', 'seticono', 'setlogo', 'setfirma',
  'miconfig', 'subprem', 'delsubprem', 'listsubprem'
]
handler.tags = ['premium']
handler.command = [
  'canjearp', 'mipremium', 'setnamebot', 'setchannel', 'setidchannel',
  'setgrupo', 'setcomunidad', 'seticono', 'setlogo', 'setfirma',
  'miconfig', 'subprem', 'delsubprem', 'listsubprem'
]

export default handler
